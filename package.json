{
  "name": "my-turborepo",
  "version": "0.0.0",
  "packageManager": "bun@1.3.10",
  "private": true,
  "description": "",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "turbo run dev --ui=tui",
    "build": "turbo run build",
    "check": "bunx ultracite check",
    "fix": "bun x ultracite fix",
    "check-types": "turbo run check-types",
    "precommit": "bun run check && bun run check-types",
    "precommit:fix": "bun run fix && bun run check-types",
    "db:push": "bun run --filter @repo/contract db:push",
    "db:generate": "bun run --filter @repo/contract db:generate",
    "db:migrate": "bun run --filter @repo/contract db:migrate",
    "db:studio": "bun run --filter @repo/contract db:studio",
    "auth:generate": "bun run --filter @repo/contract auth:generate",
    "docker:up": "docker compose -f docker/docker-compose.yml --env-file .env up postgres -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@repo/typescript-config": "workspace:*",
    "ultracite": "7.2.5",
    "turbo": "^2.9.16"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "react-hook-form": "^7.77.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "kysely": "0.28.17"
  }
}
