{
  "name": "@repo/contract",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./drizzle": "./src/drizzle/index.ts",
    "./auth": "./src/auth/index.ts",
    "./env": "./src/env.ts"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "auth:generate": "bunx @better-auth/cli generate --config src/auth/auth.ts --output src/schema/auth/schema.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.0",
    "better-auth": "^1.6.13",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20",
    "@types/pg": "^8.0.0",
    "dotenv": "^17.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
}
